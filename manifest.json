{
	"name": "ULINE Game",
	"version": "1.2",
	"manifest_version": 3,
	"description": "Guess the price of ULINE products!",
	"icons": {
		"16": "Logos/favicon-16x16.png",
		"32": "Logos/favicon-32x32.png"
	},
	"permissions": [
		"https://www.uline.com/*"
	],
	"host_permissions": [
		"https://www.uline.com/*"
	],
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "Logos/favicon-16x16.png",
			"32": "Logos/favicon-32x32.png"
		}
	},
	"content_scripts": [
		{
			"matches": ["https://www.uline.com/Product/Detail/H-*"],
			"js": ["content.js"]
		}
	]
}